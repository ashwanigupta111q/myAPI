          "script": {
            "exec": [
              "pm.test(\"Response status code is 200\", function () {\r",
              "    pm.expect(pm.response.code).to.eql(200);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Validate the presence of required fields in the response\", function () {\r",
              "    const responseData = pm.response.json();\r",
              "    \r",
              "    pm.expect(responseData).to.be.an('object');\r",
              "    pm.expect(responseData).to.have.all.keys('page', 'per_page', 'total', 'total_pages', 'data', 'support', '_meta');\r",
              "    \r",
              "    pm.expect(responseData.data).to.be.an('array');\r",
              "    pm.expect(responseData.support).to.be.an('object');\r",
              "    pm.expect(responseData._meta).to.be.an('object');\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Data array contains objects with required fields\", function () {\r",
              "    const responseData = pm.response.json();\r",
              "\r",
              "    pm.expect(responseData).to.have.property('data').that.is.an('array').that.is.not.empty;\r",
              "\r",
              "    responseData.data.forEach(function(user) {\r",
              "        pm.expect(user).to.have.all.keys('id', 'email', 'first_name', 'last_name', 'avatar');\r",
              "    });\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Response time is less than 200ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Support object contains url and text fields\", function () {\r",
              "    const responseData = pm.response.json();\r",
              "    \r",
              "    pm.expect(responseData.support).to.exist;\r",
              "    pm.expect(responseData.support).to.have.all.keys('url', 'text');\r",
              "});\r",
              "\r",
              "pm.test(\"Response has correct Content-Type header\", function () {\r",
