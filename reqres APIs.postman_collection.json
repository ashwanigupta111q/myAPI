              "});\r",
              "\r",
              "\r",
              "pm.test(\"Response contains a non-empty support object\", function () {\r",
              "    const responseData = pm.response.json();\r",
              "    \r",
              "    pm.expect(responseData).to.have.property('support').that.is.an('object').that.is.not.empty;\r",
              "});\r",
              "\r",
